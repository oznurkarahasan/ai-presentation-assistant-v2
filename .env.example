# Veritabanı Bilgileri (Yeni DB ismine dikkat)
DB_USER=admin
DB_PASSWORD=admin
DB_NAME=presentation_db_v2  # Değişti (Yeni DB ismi)

# Database URL (Docker içi iletişim için 'db_v2' kullanılmalı)
# Port Docker ağında hala 5432'dir, dışarıya 5436'dan açtık.
DATABASE_URL=postgresql+asyncpg://admin:admin@db_v2:5432/presentation_db_v2

# API Anahtarları
OPENAI_API_KEY=sk-.....
SECRET_KEY=buraya_rastgele_uzun_bir_string_yazın

ENVIRONMENT=development

# SMTP Ayarları (Kendi bilgilerini girmelisin)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=PrecueAI

# Süreler
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# Frontend URL (Yeni portumuza dikkat)
FRONTEND_URL=http://localhost:3001  # Değişti (Yeni Frontend portu)